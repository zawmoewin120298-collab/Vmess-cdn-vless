:8080 {
    # VPN WebSocket Connection ဖြစ်ပါက အတွင်းပိုင်း Port 10000 (V2Ray) ဆီ ပို့ရန်
    @is_vpn {
        header Connection *Upgrade*
        header Upgrade    websocket
    }
    reverse_proxy @is_vpn localhost:10000

    # Browser သမားများ ဝင်လာပါက True ဝက်ဘ်ဆိုက်အား လမ်းကြောင်းလွှဲပြသခြင်း
    handle {
        reverse_proxy https://www.true.th {
            header_up Host www.true.th
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
            header_up Accept-Encoding identity
        }
    }
}
