:80 {
    # ၁။ ဝက်ဘ်ဆိုက်အတွက် မနက်ကအတိုင်း ပုံမှန် Root Folder လမ်းကြောင်း
    root * /usr/share/caddy
    file_server
    php_fastcgi 127.0.0.1:9000

    # ၂။ VPN ချိတ်ဆက်မှုအတွက် Path ကို သီးသန့် အပြတ်ခွဲထုတ်ခြင်း
    # အပြင်ကနေ /vless-cdn ဆိုတဲ့ လမ်းကြောင်းနဲ့ လာမှသာ Port 8080 (V2Ray) ထဲကို ပို့ပေးမည်
    handle /vless-cdn {
        reverse_proxy 127.0.0.1:8080
    }
}
