:80 {
    # trueth.kdns.fr နဲ့ ဝင်လာရင် အစ်ကို့ရဲ့ Node Store ဝက်ဘ်ဆိုက်ကို ပုံမှန်အတိုင်း ပြပေးရန်
    root * /usr/share/caddy
    file_server

    # ၁။ VPN ချိတ်ဆက်မှု (Path) ဖြစ်တဲ့ /vless-cdn နဲ့ လာသမျှ Request အားလုံးကို
    # Port 8080 ထဲက V2Ray ဆီ မပို့တော့ဘဲ true.co.th ဆီသို့ အနောက်ကနေ တိုက်ရိုက် လမ်းကြောင်း ပြောင်းညွှန်ပေးရန်
    handle /vless-cdn {
        reverse_proxy https://true.co.th {
            header_up Host true.co.th
        }
    }

    # ၂။ ရိုးရိုး ဝက်ဘ်ဆိုက် လာကြည့်သူများကိုသာ PHP စနစ်ဆီ ပို့ရန်
    handle {
        php_fastcgi 127.0.0.1:9000
    }
}

