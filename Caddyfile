http://trueth.kdns.fr {
    # ၁။ WebSocket Traffic ကို V2Ray ဆီ ပို့ပေးခြင်း
    # အပြင်ကနေ /ray လမ်းကြောင်းနဲ့လာသမျှကို အထဲက Port 8080 ဆီ ပို့ပါမယ်
    handle /ray {
        reverse_proxy localhost:8080
    }

    # ၂။ ရိုးရိုး Browser က ဝင်လာရင် Speedtest (သို့မဟုတ် ပြင်ပ URL) ကို အနောက်ကွယ်ကနေ လှမ်းပြပေးခြင်း
    # ဒီနေရာမှာ speedtest.net ရဲ့ မူရင်း Host Header ကိုပါ ထည့်ပေးရမှာ ဖြစ်ပါတယ်
    handle {
        reverse_proxy https://www.speedtest.net {
            header_up Host www.speedtest.net
        }
    }
}
