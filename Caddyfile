www.true.th {
    # ဝက်ဘ်ဆိုက်ဖိုင်များရှိရာ နေရာသတ်မှတ်ခြင်း
    root * /usr/share/caddy
    file_server

    # ၁။ VPN ချိတ်ဆက်မှုအတွက် လမ်းကြောင်းကို ခွဲထုတ်ခြင်း
    # အပြင်ကနေ www.true.th/vless-cdn နဲ့ လာသမျှကို Port 8080 (V2Ray) ဆီ တန်းပို့မည်
    handle /vless-cdn {
        reverse_proxy 127.0.0.1:8080
    }

    # ၂။ ရိုးရိုး Web ဝင်ကြည့်သူများကိုသာ PHP ဝက်ဘ်ဆိုက်ဆီ ပို့ခြင်း
    handle {
        php_fastcgi 127.0.0.1:9000
    }
}
