trueth.kdns.fr {
    # VPN ချိတ်ဆက်မှုများကို Path မခွဲခြားဘဲ အနောက်ကွယ်က Port 8080 ဆီ ပို့ပေးခြင်း
    reverse_proxy localhost:8080 {
        header_up Upgrade {http.request.header.Upgrade}
        header_up Connection {http.request.header.Connection}
    }

    # Browser သမားများအတွက် True ဝက်ဘ်ဆိုက်အား အစားထိုးပြသပေးခြင်း
    handle {
        reverse_proxy https://www.true.th {
            header_up Host www.true.th
            header_up Accept-Encoding identity
        }
    }
}
